# (here or auto-egress/agent-started) still lands via the egress_ended webhook.
LIVEKIT_RECORD_BUCKET=
LIVEKIT_RECORD_REGION=eu-north-1
LIVEKIT_RECORD_ACCESS_KEY=cc8d0695dbca7d9ba9338e79fa27d206
LIVEKIT_RECORD_SECRET=4ad3b44f24424f5f695fa0b1cd888c15c37c91cc70fda0e24f178a8c7e5c15b8
# Optional S3-compatible endpoint (Cloudflare R2 / MinIO / Backblaze); blank = AWS S3
LIVEKIT_RECORD_ENDPOINT=
LIVEKIT_RECORD_PREFIX=recordings


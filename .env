# Production environment — copy to .env on the server only (never commit .env).
# Used by docker compose for build args and runtime env.

WEB_PORT=3000

# Required for Next.js build (inlined at build time) and runtime Supabase clients
NEXT_PUBLIC_SUPABASE_URL=https://ytozpjohaphinlsqrxlc.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Qy-kFKCT4BE33yKvkrZQtQ_EphHUJbK

# Invite-only: create users in Supabase Dashboard (Authentication → Users).
# Disable public signups: Authentication → Providers → Email → Allow new users to sign up = off.

# Dashboard auto-refresh while logged in (milliseconds). Default 15000 if unset.
NEXT_PUBLIC_POLL_INTERVAL_MS=15000

# ── LiveKit telephony gateway (same path Seeker/Grace use) ──────────────────
# Leave these blank to keep the simulator fallback; fill them in to dial real calls.
# Twilio/Telnyx are configured as the SIP outbound *trunk* inside LiveKit (via `lk` CLI),
# not called directly here.
LIVEKIT_URL=wss://deepspec-10yabi4p.livekit.cloud
LIVEKIT_API_KEY=APItSmH976Z3xUw
LIVEKIT_API_SECRET=GPLeS1LBkc5qFnANcNLfmZaevG6tQzb4fPGUAvQdD8HD
# SIP outbound trunk id from LiveKit (looks like ST_xxxxxxxx)
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_WA6igGKNZRLf
# Agent dispatch name the worker registers under (e.g. the Seeker/Grace outbound agent)
LIVEKIT_AGENT_NAME=jonathan-agent-latest

# ── Inworld TTS (campaign voice generation) ──
# Base64 key from Inworld → Integrations, used as `Authorization: Basic <key>`.
INWORLD_API_KEY=YWxwY2Q4V3hxa1NuRU1HRGFUdkNLQVI4dFNYSG5MYXo6UjZ5cXp5eWRVSlFuQzBHbllRYnFDSEV0cllRQk5zNTlzZnBmekRFVUlHREFKbkpUYzlGTzZEcFViVGdQZnhwRA==
INWORLD_TTS_MODEL=inworld-tts-1.5-max
INWORLD_TTS_VOICE_ID=default-hzau9tlenfqr0yc2k7co6g__charlotte

# ── Service-role key — server-to-server DB writes (webhook + agent result) ──
# These callers have no user session, so they bypass RLS with the service role.
# Supabase Dashboard → Project Settings → API → service_role secret. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl0b3pwam9oYXBoaW5sc3FyeGxjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTA3MzU1NCwiZXhwIjoyMDk2NjQ5NTU0fQ.W4R5rMT1UiN5WsV7SOE__l7ZDoZD9FHsOzw4_zB5kGw

# ── Call recording (LiveKit Egress → S3-compatible storage) ─────────────────
# Optional: leave blank and calls still place, recording_url just stays null. Any egress
# (here or auto-egress/agent-started) still lands via the egress_ended webhook.
LIVEKIT_RECORD_BUCKET=
LIVEKIT_RECORD_REGION=us-east-1
LIVEKIT_RECORD_ACCESS_KEY=
LIVEKIT_RECORD_SECRET=
# Optional S3-compatible endpoint (Cloudflare R2 / MinIO / Backblaze); blank = AWS S3
LIVEKIT_RECORD_ENDPOINT=
LIVEKIT_RECORD_PREFIX=recordings

# ── Agent → app result endpoint (/api/calls/result) ─────────────────────────
# Shared secret the LiveKit agent sends as `x-agent-secret` when posting call outcomes.
AGENT_RESULT_SECRET=

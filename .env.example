# Production environment — copy to .env on the server only (never commit .env).
# Used by docker compose for build args and runtime env.

WEB_PORT=3000

# Required for Next.js build (inlined at build time) and runtime Supabase clients
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Invite-only: create users in Supabase Dashboard (Authentication → Users).
# Disable public signups: Authentication → Providers → Email → Allow new users to sign up = off.

# ── Service-role key (server-side only; NEVER expose to the browser) ─────────
# Used to sign private voice-recording URLs for in-app preview.
# Supabase Dashboard → Project Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Demo mode ───────────────────────────────────────────────────────────────
# When true, API routes return seeded DEMO_* data if the DB is empty. Leave false/unset
# in production so the dashboard reflects real evra_callops data.
DEMO_MODE=false

# NOTE: LiveKit, SIP trunk, call recording (egress) and the agent result endpoint are
# configured on the evra_callops service, NOT here. This app is a Supabase control plane
# + reporting surface only — it never dials.

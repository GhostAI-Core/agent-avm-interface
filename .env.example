# Production environment — copy to .env on the server only (never commit .env).
# Used by docker compose for build args and runtime env.

WEB_PORT=3000

# Required for Next.js build (inlined at build time) and runtime Supabase clients
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Invite-only: create users in Supabase Dashboard (Authentication → Users).
# Disable public signups: Authentication → Providers → Email → Allow new users to sign up = off.

# Dashboard auto-refresh while logged in (milliseconds). Default 15000 if unset.
NEXT_PUBLIC_POLL_INTERVAL_MS=15000

# ── LiveKit telephony gateway ───────────────────────────────────────────────
# Used for webhook validation and direct diagnostic CLI calls. Production campaign
# dispatch is owned by evra-callops.
# Twilio/Telnyx are configured as the SIP outbound *trunk* inside LiveKit (via `lk` CLI),
# not called directly here.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# SIP outbound trunk id from LiveKit (looks like ST_xxxxxxxx)
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Agent dispatch name the worker registers under (e.g. the Seeker/Grace outbound agent)
LIVEKIT_AGENT_NAME=outbound-agent

# ── Service-role key — server-to-server DB writes ──────────────────────────
# These callers have no user session, so they bypass RLS with the service role.
# Supabase Dashboard → Project Settings → API → service_role secret. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Call recording (LiveKit Egress → S3-compatible storage) ─────────────────
# Optional: leave blank and calls still place, recording_url just stays null. Any egress
# (here or auto-egress/agent-started) still lands via the egress_ended webhook.
LIVEKIT_RECORD_BUCKET=
LIVEKIT_RECORD_REGION=us-east-1
LIVEKIT_RECORD_ACCESS_KEY=
LIVEKIT_RECORD_SECRET=
# Optional S3-compatible endpoint (Cloudflare R2 / MinIO / Backblaze); blank = AWS S3
LIVEKIT_RECORD_ENDPOINT=
LIVEKIT_RECORD_PREFIX=recordings

# ── evra-callops orchestrator (issue #34) ───────────────────────────────────
# Outbound call lifecycle (start/pause/stop) + live stats are owned by evra-callops.
# The frontend proxies these server-side so the shared secret never reaches the browser.
# Leave blank in local dev — lifecycle actions then fall back to a direct status write.
CALLOPS_URL=https://call-center.evra-ai.com
# Same value as WEBHOOK_SECRET in the evra-callops .env. Sent as the X-Webhook-Secret header.
CALLOPS_WEBHOOK_SECRET=

# ── Inworld TTS (optional — campaign voice generation) ─────────────────────
# Base64 Basic auth credential only (no "Basic " prefix). Server-only.
INWORLD_API_KEY=

# ── AVM script audio storage (optional — generated campaign scripts) ───────
# Upload via Supabase S3 (PutObject). Files: script-{campaign-slug}-{DD-MM-YYYY}.mp3
AVM_SCRIPT_AUDIO_STORAGE_BUCKET=avm-scripts
AVM_SCRIPT_AUDIO_STORAGE_REGION=eu-north-1
AVM_SCRIPT_AUDIO_STORAGE_ACCESS_KEY=
AVM_SCRIPT_AUDIO_STORAGE_SECRET=
# Public URL base for playback (not the S3 API endpoint).
AVM_SCRIPT_AUDIO_STORAGE_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/object/public/avm-scripts
# Optional — defaults to https://{project-ref}.storage.supabase.co/storage/v1/s3
# AVM_SCRIPT_AUDIO_STORAGE_S3_ENDPOINT=
AVM_SCRIPT_AUDIO_STORAGE_PREFIX=script-

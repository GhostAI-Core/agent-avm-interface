# Production environment — copy to .env on the server only (never commit .env).
# Used by docker compose for build args and runtime env.

WEB_PORT=3000

# Required for Next.js build (inlined at build time) and runtime Supabase clients
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Invite-only: create users in Supabase Dashboard (Authentication → Users).
# Disable public signups: Authentication → Providers → Email → Allow new users to sign up = off.

# Dashboard auto-refresh while logged in (milliseconds). Default 15000 if unset.
NEXT_PUBLIC_POLL_INTERVAL_MS=15000

# ── LiveKit telephony gateway (same path Seeker/Grace use) ──────────────────
# Required for outbound dialing via LiveKit.
# Twilio/Telnyx are configured as the SIP outbound *trunk* inside LiveKit (via `lk` CLI),
# not called directly here.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
# Legacy/default direct LiveKit → carrier trunk (routing_mode = legacy).
# From `lk sip outbound list` — looks like ST_xxxxxxxx.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Routr-facing LiveKit trunk (routing_mode = routr).
# This LiveKit trunk should point to the Routr VPS/SIP domain, not directly to Utility Connect.
# Use LIVEKIT_SIP_ROUTR_TRUNK_ID only for campaigns with routing_mode = routr (or CLI --route routr).
LIVEKIT_SIP_ROUTR_TRUNK_ID=
# Host public IPv4 — Routr EXTERNAL_ADDRS and LiveKit SIP trunk address (not Cloudflare hostname)
ROUTR_PUBLIC_IP=
# Internal Docker URL for web app → Routr API (M2 sync); bootstrap uses agent-avm-sip-routr:51908
# M2: Settings UI syncs voip_providers + LiveKit peer via lib/routr; env vars below remain deploy fallback.
ROUTR_API_ENDPOINT=insecure://agent-avm-sip-routr:51908
# Optional: LiveKit SIP source CIDR (comma-separated in Routr ACL)
ROUTR_LIVEKIT_ALLOWED_CIDRS=
ROUTR_LIVEKIT_SIP_HOST=your-project.sip.livekit.cloud:5060
# Routr contactAddr column is VARCHAR(20) — use IP:port if hostname resolves too long.
# Bootstrap auto-resolves hostnames via DNS; for outbound-only M1, contactAddr may be omitted.
ROUTR_LIVEKIT_PEER_USERNAME=livekit
ROUTR_LIVEKIT_PEER_PASSWORD=
# Carrier trunk — Utility Connect (bootstrap applies when ROUTR_CARRIER_SIP_HOST is set)
# ROUTR_CARRIER_NAME may use underscores; Routr inbound URI becomes utility-connect.evra.local
# Caller ID (+27104760561) is set on the LiveKit Routr outbound trunk Numbers field, not here.
ROUTR_CARRIER_NAME=utility_connect
ROUTR_CARRIER_SIP_HOST=sbc.convergedgroup.co.za
ROUTR_CARRIER_SIP_PORT=5060
ROUTR_CARRIER_SIP_USERNAME=uc-jono
ROUTR_CARRIER_SIP_PASSWORD=
# Agent dispatch name the worker registers under (e.g. the Seeker/Grace outbound agent)
LIVEKIT_AGENT_NAME=outbound-agent

# ── Service-role key — server-to-server DB writes (webhook + agent result) ──
# These callers have no user session, so they bypass RLS with the service role.
# Supabase Dashboard → Project Settings → API → service_role secret. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Call recording (LiveKit Egress → S3-compatible storage) ─────────────────
# Optional: leave blank and calls still place, recording_url just stays null. Any egress
# (here or auto-egress/agent-started) still lands via the egress_ended webhook.
LIVEKIT_RECORD_BUCKET=
LIVEKIT_RECORD_REGION=us-east-1
LIVEKIT_RECORD_ACCESS_KEY=
LIVEKIT_RECORD_SECRET=
# Optional S3-compatible endpoint (Cloudflare R2 / MinIO / Backblaze); blank = AWS S3
LIVEKIT_RECORD_ENDPOINT=
LIVEKIT_RECORD_PREFIX=recordings

# ── Agent → app result endpoint (/api/calls/result) ─────────────────────────
# Shared secret the LiveKit agent sends as `x-agent-secret` when posting call outcomes.
AGENT_RESULT_SECRET=

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Invite-only: create users in Supabase Dashboard (Authentication → Users).
# Disable public signups: Authentication → Providers → Email → Allow new users to sign up = off.
# Remove NEXT_PUBLIC_DEV_AUTH_BYPASS from .env if present — it bypasses login without a Supabase session.

# ── LiveKit (required for outbound dialing) ───────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Legacy path (routing_mode = legacy): direct LiveKit → carrier trunk
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Routr path (routing_mode = routr): LiveKit → Routr → carrier
LIVEKIT_SIP_ROUTR_TRUNK_ID=
LIVEKIT_AGENT_NAME=outbound-agent
SUPABASE_SERVICE_ROLE_KEY=

{"nodes": [{"id": "2026_06_10_evra_chart_palette_design_chart_theme_module", "label": "lib/chartTheme.ts central chart styling", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L27-L33", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chart-specific semantics (outcome colours, glow, gradients) stay separate from general UI tokens in tokens.ts; extending tokens.ts only was rejected because the palette is large and helpers do not belong in general design tokens."}, {"id": "2026_06_10_evra_chart_palette_design_bar_gradient_helper", "label": "createBarGradient canvas helper", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L35-L39", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chart.js requires canvas context at render time; a helper keeps Charts.tsx clean while enabling vertical bar gradients in Campaign Comparison."}, {"id": "2026_06_10_evra_chart_palette_design_dataset_shadow_glow", "label": "Chart.js dataset shadowBlur glow", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L41-L45", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Built-in shadow properties apply glow to data elements only with minimal complexity; donut uses brighter stroke borders instead of per-slice glow."}, {"id": "2026_06_10_evra_chart_palette_design_connected_qualified_colours", "label": "Connected vs Qualified colour distinction", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L13-L14", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Connected (#47D16A green) and Qualified (#5BE8BE mint/aqua) must be visually distinct; per-agent colour tinting was removed for clarity."}, {"id": "2026_06_10_evra_chart_palette_design_migration_plan", "label": "Chart palette migration plan", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L66-L74", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Add chartTheme.ts, update tokens.ts aliases, refactor Charts.tsx, add CSS variables, manual QA. Rollback reverts four files with no data or API changes."}], "edges": [{"source": "2026_06_10_evra_chart_palette_design_chart_theme_module", "target": "chart_visual_system_spec_centralised_tokens", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L27-L33", "weight": 1.0}, {"source": "2026_06_10_evra_chart_palette_design_chart_theme_module", "target": "evra_design_tokens_spec_typescript_mirror", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L29-L33", "weight": 1.0}, {"source": "2026_06_10_evra_chart_palette_design_migration_plan", "target": "2026_06_10_evra_chart_palette_design_chart_theme_module", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L66-L74", "weight": 1.0}, {"source": "2026_06_10_evra_chart_palette_design_bar_gradient_helper", "target": "2026_06_10_evra_chart_palette_design_dataset_shadow_glow", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "openspec/changes/archive/2026-06-10-evra-chart-palette/design.md", "source_location": "L35-L45", "weight": 1.0}], "hyperedges": []}
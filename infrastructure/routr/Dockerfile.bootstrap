FROM node:20-alpine

WORKDIR /app

COPY infrastructure/routr/bootstrap.package.json ./package.json
RUN npm install --omit=dev --no-audit --no-fund \
  && npm install tsx --save-dev --no-audit --no-fund

COPY lib/routr ./lib/routr
COPY infrastructure/routr/bootstrap.sh infrastructure/routr/bootstrap-run.ts ./infrastructure/routr/

ENTRYPOINT ["/bin/sh", "/app/infrastructure/routr/bootstrap.sh"]
